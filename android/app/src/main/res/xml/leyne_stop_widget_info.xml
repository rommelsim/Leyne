<?xml version="1.0" encoding="utf-8"?>
<!-- Pinned Stop widget — small (2x2) / medium (4x2). updatePeriodMillis=0
     because WidgetRefreshWorker (WorkManager) + the Dart WidgetBridge drive
     updates; the system's own periodic update is disabled. The configure
     activity lets each instance pick which pinned stop it shows. -->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="110dp"
    android:targetCellWidth="2"
    android:targetCellHeight="2"
    android:maxResizeWidth="250dp"
    android:maxResizeHeight="110dp"
    android:resizeMode="horizontal"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/glance_default_loading_layout"
    android:configure="com.leyne.leyne.widget.StopPickerActivity"
    android:widgetCategory="home_screen"
    android:description="@string/widget_stop_desc"
    android:previewImage="@drawable/widget_preview_stop" />

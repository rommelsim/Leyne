<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- LTA DataMall requests + AdMob -->
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Nearby uses device GPS via geolocator (Task #7). Fine + coarse cover
         both precise and approximate location options surfaced to the user. -->
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION"/>
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION"/>
    <!-- Required for AdMob to read the Advertising ID on Android 13+ (API
         33+). Without it, ads still serve but in degraded-targeting mode.
         Combined with the consent flow in lib/services/ad_consent.dart so
         the SDK only reads the ID after UMP consent is granted. The Play
         Store Data Safety form must disclose "Device or other IDs" → AdMob
         when this permission is present. Moves in lock-step with
         kLyneAdsEnabled in lib/widgets/ad_banner.dart. -->
    <uses-permission android:name="com.google.android.gms.permission.AD_ID"/>
    <!-- Arrival- and alight-alert notifications (lib/services/notifications.dart).
         POST_NOTIFICATIONS is the Android 13+ runtime permission; we
         request it at the moment the user toggles "Arrival alerts" on.
         SCHEDULE_EXACT_ALARM lets zonedSchedule fire alarms at the
         intended moment (not batched in the system's Doze maintenance
         window). Auto-granted on Android 12–13; on Android 14+ the
         user grants it once via system Settings (we surface the prompt
         via permission_handler). Note: this is the un-restricted
         permission; we do NOT declare USE_EXACT_ALARM, which Play
         restricts to alarm/calendar apps. Without exact alarms our
         "1 minute before arrival" heads-up would drift by minutes in
         Doze — unacceptable for a bus alert.
         RECEIVE_BOOT_COMPLETED lets flutter_local_notifications re-arm
         pending schedules after a reboot. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!-- WorkManager background tasks (leyne.alertsRefresh periodic poll).
         FOREGROUND_SERVICE is required when WorkManager is configured to run
         as an expedited job on Android 12+ (not currently the case here, but
         included so upgrading to expedited mode later doesn't break silently).
         No WAKE_LOCK declaration is needed — WorkManager holds a wake lock
         internally for the duration of each task run. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>

    <application
        android:label="SG Transit"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="true">

        <!-- enableOnBackInvokedCallback: opt into the Android 13+ predictive-back
             dispatcher. WITHOUT this, on Android 13/14 (incl. Xiaomi HyperOS /
             MIUI, which default to gesture nav) the system back BYPASSES
             Flutter's PopScope and finishes the activity directly — i.e. the
             app exits and SoftRoot's back-stack handling never runs. With it,
             back is delivered to the framework so the PopScope retrace logic in
             lib/screens/v2/soft_root.dart takes effect on every OEM. -->

        <!-- Maps use flutter_map with free CartoDB raster tiles (no API key,
             no billing) — a modern style, not the dated default OSM raster.
             iOS uses Apple Maps. No Google Maps SDK key is needed. -->

        <!-- Google Mobile Ads SDK app ID — leyne0000 AdMob publisher.
             The Android ad UNIT is gated by build mode in
             lib/widgets/ad_banner.dart (test in DEBUG, real in RELEASE). -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-5864511655536507~5685985257"/>
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:screenOrientation="portrait"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

            <!-- App Links: lyne.sg/stop/{code}, /service/{busNo}. autoVerify
                 makes Play check /.well-known/assetlinks.json on install so
                 the OS opens these URIs in our app without a chooser dialog.
                 Until the assetlinks.json file is hosted, this still works
                 (the OS just shows a chooser the first time). -->
            <intent-filter android:autoVerify="true">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="https"/>
                <data android:host="lyne.sg"/>
                <data android:pathPrefix="/stop"/>
                <data android:pathPrefix="/service"/>
            </intent-filter>

            <!-- Custom URL scheme for testing without hosting assetlinks.json.
                 lyne://stop/83139 opens the app directly. -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="lyne"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- WorkManager service for the leyne.alertsRefresh background task.
             The workmanager Flutter plugin uses its own JobService subclass
             (be.tramckrijte.workmanager.BackgroundWorker) to host each task.
             `android:exported="false"` keeps it private — WorkManager is the
             only caller. The DartWorkerTask and related classes are provided
             by the workmanager plugin; no additional Kotlin code is needed
             beyond the plugin's auto-registration via FlutterActivity. -->
        <service
            android:name="be.tramckrijte.workmanager.BackgroundWorker"
            android:exported="false"
            android:permission="android.permission.BIND_JOB_SERVICE"/>

        <!-- flutter_local_notifications receivers — fire the broadcast that
             becomes a system notification at the scheduled time, and re-
             register pending schedules after a device reboot. -->
        <receiver android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationReceiver"
            android:exported="false"/>
        <receiver android:name="com.dexterous.flutterlocalnotifications.ScheduledNotificationBootReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
                <action android:name="android.intent.action.QUICKBOOT_POWERON"/>
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON"/>
            </intent-filter>
        </receiver>

        <!-- ── Home-screen widgets (Jetpack Glance) ───────────────────────
             Each GlanceAppWidgetReceiver is an AppWidgetProvider; the Dart
             WidgetBridge writes their data (via home_widget) and pokes them
             with HomeWidget.updateWidget(qualifiedAndroidName: …). The Stop
             and Fav widgets have an APPWIDGET_CONFIGURE activity so the user
             picks which pinned stop / favourite service that instance shows;
             the Nearest widget needs no configuration. Taps launch MainActivity
             with a lyne:// VIEW intent → DeepLinkService. -->
        <receiver
            android:name=".widget.LeyneNearbyWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_nearby_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/leyne_nearby_widget_info"/>
        </receiver>
        <receiver
            android:name=".widget.LeyneFavServiceWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_fav_label">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/leyne_fav_widget_info"/>
        </receiver>

        <activity
            android:name=".widget.FavPickerActivity"
            android:exported="false"
            android:theme="@style/Theme.AppCompat.DayNight.Dialog">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_CONFIGURE"/>
            </intent-filter>
        </activity>
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
